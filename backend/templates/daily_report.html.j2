<!DOCTYPE html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{{ title }} {{ date }}</title>
    <style>
      :root {
        --brand: #2f6bff;
        --brand-deep: #1b4fcb;
        --brand-soft: #e8efff;
        --bg: #f4f7fd;
        --card: #ffffff;
        --text: #1e2430;
        --muted: #8993a4;
        --line: #e8edf6;
      }
      * { box-sizing: border-box; }
      body {
        margin: 0;
        background:
          radial-gradient(circle at 0% 0%, #dbe7ff 0, transparent 38%),
          radial-gradient(circle at 100% 16%, #e9f1ff 0, transparent 42%),
          var(--bg);
        color: var(--text);
        font-family: "PingFang SC", "Hiragino Sans GB", "Microsoft YaHei", sans-serif;
      }
      .wrap {
        max-width: 980px;
        margin: 0 auto;
        padding: 18px 14px 30px;
      }
      .cover {
        position: relative;
        overflow: hidden;
        background: linear-gradient(135deg, #4b8bff, #2f6bff 62%, #1b4fcb);
        border-radius: 24px;
        padding: 18px;
        color: #fff;
        box-shadow: 0 14px 34px rgba(47, 107, 255, 0.34);
      }
      .cover::after {
        content: "";
        position: absolute;
        right: -20px;
        top: -26px;
        width: 120px;
        height: 120px;
        border-radius: 50%;
        background: rgba(255, 255, 255, 0.12);
      }
      .cover-top {
        position: relative;
        z-index: 1;
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 12px;
      }
      .brand-chip {
        font-size: 13px;
        border: 1px solid rgba(255, 255, 255, 0.45);
        border-radius: 999px;
        padding: 4px 10px;
        background: rgba(255, 255, 255, 0.12);
      }
      .date { font-size: 13px; opacity: 0.92; }
      .cover-main {
        position: relative;
        z-index: 1;
        display: grid;
        grid-template-columns: 1.1fr 1fr;
        gap: 12px;
      }
      .cover-image {
        min-height: 170px;
        border-radius: 18px;
        border: 1px solid rgba(255,255,255,0.22);
        background:
          linear-gradient(180deg, rgba(255,255,255,0.12), rgba(255,255,255,0.02)),
          repeating-linear-gradient(
            135deg,
            rgba(255,255,255,0.11) 0,
            rgba(255,255,255,0.11) 8px,
            rgba(255,255,255,0.02) 8px,
            rgba(255,255,255,0.02) 16px
          );
        display: flex;
        align-items: end;
        padding: 12px;
      }
      .cover-image span {
        display: inline-block;
        padding: 4px 8px;
        border-radius: 999px;
        background: rgba(255,255,255,0.16);
        font-size: 12px;
      }
      .cover-content h1 {
        margin: 0 0 8px;
        font-size: 30px;
        line-height: 1.2;
      }
      .cover-subtitle {
        margin: 0;
        font-size: 14px;
        opacity: 0.94;
      }
      .metrics {
        margin-top: 12px;
        display: grid;
        gap: 8px;
      }
      .metric {
        background: rgba(255, 255, 255, 0.14);
        border: 1px solid rgba(255, 255, 255, 0.26);
        border-radius: 14px;
        padding: 10px 12px;
      }
      .metric-label { font-size: 12px; opacity: 0.94; }
      .metric-value { margin-top: 4px; font-size: 24px; font-weight: 700; }
      .section-title { margin: 18px 2px 10px; font-size: 20px; }
      .section-sub { margin: -2px 2px 12px; color: var(--muted); font-size: 13px; }
      .recommend { display: grid; gap: 10px; }
      .recommend-card {
        background: var(--card);
        border: 1px solid var(--line);
        border-radius: 16px;
        padding: 12px;
        box-shadow: 0 6px 16px rgba(38, 58, 103, 0.06);
      }
      .tag {
        display: inline-block;
        margin-bottom: 7px;
        padding: 3px 8px;
        border-radius: 999px;
        background: var(--brand-soft);
        color: var(--brand);
        font-size: 12px;
        font-weight: 600;
      }
      .tag.hot-tag {
        background: #fff1f4;
        color: #d73a49;
      }
      h3, h4 { margin: 0; }
      .meta { margin: 7px 0 0; color: var(--muted); font-size: 12px; }
      .abs { margin: 8px 0 0; line-height: 1.65; color: #3a4353; font-size: 14px; }
      .avatar {
        width: 30px;
        height: 30px;
        border-radius: 50%;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        background: var(--brand-soft);
        color: var(--brand-deep);
        font-size: 12px;
        font-weight: 700;
        margin-right: 6px;
        vertical-align: middle;
      }
      a { color: var(--brand-deep); text-decoration: none; }
      .note-feed { column-count: 2; column-gap: 10px; }
      .note {
        display: inline-block;
        width: 100%;
        margin: 0 0 10px;
        background: var(--card);
        border: 1px solid var(--line);
        border-radius: 14px;
        padding: 11px;
        break-inside: avoid;
      }
      .note-media {
        width: 100%;
        border-radius: 10px;
        margin-bottom: 8px;
        background: linear-gradient(160deg, #eef3ff, #dce8ff);
      }
      .media-a { height: 78px; }
      .media-b { height: 108px; }
      .media-c { height: 92px; }
      .note-section {
        display: inline-block;
        margin-bottom: 7px;
        padding: 2px 8px;
        border-radius: 999px;
        background: #f0f4ff;
        color: #4d66a8;
        font-size: 12px;
      }
      .note h4 { font-size: 15px; line-height: 1.48; }
      .project-grid {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 10px;
      }
      .project {
        position: relative;
        background: var(--card);
        border: 1px solid var(--line);
        border-radius: 14px;
        padding: 11px;
      }
      .project h4 { font-size: 15px; padding-right: 62px; }
      .like-corner {
        position: absolute;
        right: 10px;
        top: 10px;
        font-size: 11px;
        padding: 2px 7px;
        border-radius: 999px;
        color: #d73a49;
        background: #fff1f4;
      }
      .empty {
        padding: 12px;
        background: var(--card);
        border: 1px dashed #d9e1ef;
        border-radius: 12px;
        color: var(--muted);
        font-size: 13px;
      }
      @media (max-width: 760px) {
        .cover-main { grid-template-columns: 1fr; }
        .cover-content h1 { font-size: 26px; }
        .note-feed { column-count: 1; }
        .project-grid { grid-template-columns: 1fr; }
      }
    </style>
  </head>
  <body>
    <div class="wrap">
      <section class="cover">
        <div class="cover-top">
          <span class="brand-chip">Research Notes</span>
          <span class="date">{{ date }}</span>
        </div>
        <div class="cover-main">
          <div class="cover-image"><span>封面主图位</span></div>
          <div class="cover-content">
            <h1>{{ title }}</h1>
            <p class="cover-subtitle">每日自动更新 · 论文筛选 · 热门项目速览</p>
            <div class="metrics">
              <div class="metric">
                <div class="metric-label">关键词命中论文</div>
                <div class="metric-value">{{ total_papers }}</div>
              </div>
              <div class="metric">
                <div class="metric-label">Github 热门项目</div>
                <div class="metric-value">{{ total_projects }}</div>
              </div>
            </div>
          </div>
        </div>
      </section>

      <h2 class="section-title">今日推荐</h2>
      <p class="section-sub">按命中关键词与发布时间综合排序</p>
      {% if recommended %}
        <section class="recommend">
          {% for paper in recommended %}
            <article class="recommend-card">
              <span class="tag {% if loop.index == 1 %}hot-tag{% endif %}">{% if loop.index == 1 %}爆{% else %}新{% endif %}</span>
              <h3>{{ paper.title }}</h3>
              <p class="meta">
                <span class="avatar">{{ (paper.authors[0][0] if paper.authors else "R")|upper }}</span>
                {{ ", ".join(paper.authors) if paper.authors else "N/A" }} · {{ paper.publish_time.date().isoformat() }}
              </p>
              <p class="abs">{{ paper.abstract[:260] }}{% if paper.abstract|length > 260 %}...{% endif %}</p>
              <p class="meta"><a href="{{ paper.url }}" target="_blank">查看原文</a></p>
            </article>
          {% endfor %}
        </section>
      {% else %}
        <div class="empty">今日暂无推荐论文。</div>
      {% endif %}

      <h2 class="section-title">论文笔记流</h2>
      <p class="section-sub">双列瀑布流卡片，移动端自动单列</p>
      {% if sections %}
        <section class="note-feed">
          {% for section_name, items in sections.items() %}
            {% for paper in items[:6] %}
              <article class="note">
                <div class="note-media {% if loop.index0 % 3 == 0 %}media-a{% elif loop.index0 % 3 == 1 %}media-b{% else %}media-c{% endif %}"></div>
                <span class="note-section">{{ section_name }}</span>
                <h4>{{ paper.title }}</h4>
                <p class="meta">
                  <span class="avatar">{{ (paper.authors[0][0] if paper.authors else "R")|upper }}</span>
                  {{ paper.publish_time.date().isoformat() }} · {{ paper.source }}
                </p>
                <p class="abs">{{ paper.abstract[:150] }}{% if paper.abstract|length > 150 %}...{% endif %}</p>
                <p class="meta"><a href="{{ paper.url }}" target="_blank">继续阅读</a></p>
              </article>
            {% endfor %}
          {% endfor %}
        </section>
      {% else %}
        <div class="empty">今日没有命中关键词的论文。</div>
      {% endif %}

      <h2 class="section-title">Github 热门项目</h2>
      {% if top_projects %}
        <section class="project-grid">
          {% for project in top_projects %}
            <article class="project">
              <span class="like-corner">❤ 点赞感</span>
              <h4><a href="{{ project.url }}" target="_blank">{{ project.name }}</a></h4>
              <p class="meta">{{ project.language }} · ⭐ {{ project.stars }}</p>
              <p class="abs">{{ project.description or "暂无描述" }}</p>
            </article>
          {% endfor %}
        </section>
      {% else %}
        <div class="empty">今日未抓取到热门项目。</div>
      {% endif %}
    </div>
  </body>
</html>

